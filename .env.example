# ─── DATABASE ─────────────────────────────────────────────────
# PostgreSQL — Render provides two URLs from the database dashboard:
#
#   DATABASE_URL  → use the "Internal Database URL" (pooled, for ORM)
#   DIRECT_URL    → use the "Internal Database URL" (same, for migrations)
#
# Local development example:
DATABASE_URL="postgresql://postgres:password@localhost:5432/neontrade"
DIRECT_URL="postgresql://postgres:password@localhost:5432/neontrade"

JWT_SECRET="change-this-to-a-long-random-secret"

# ─── SINGLE AUTHORIZED USER ───────────────────────────────────
# This platform is a private single-user trading journal system.
# Set these to configure the one authorized login account.
ADMIN_EMAIL="journal@obieda.com"
ADMIN_PASSWORD="your-secure-password-here"
ADMIN_USERNAME="journal"
